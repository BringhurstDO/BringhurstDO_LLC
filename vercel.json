{
  "crons": [
    {
      "path": "/api/cron/ops-autopublish/morning",
      "schedule": "0 13 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/morning",
      "schedule": "0 14 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/midday",
      "schedule": "0 16 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/midday",
      "schedule": "0 17 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/afternoon",
      "schedule": "0 19 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/afternoon",
      "schedule": "0 20 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/evening",
      "schedule": "0 22 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/evening",
      "schedule": "0 23 * * 1-6"
    },
    {
      "path": "/api/cron/ops-autopublish/late-evening",
      "schedule": "0 1 * * 0,2-6"
    },
    {
      "path": "/api/cron/ops-autopublish/late-evening",
      "schedule": "0 2 * * 0,2-6"
    },
    {
      "path": "/api/cron/ops-x-metrics",
      "schedule": "0 15 * * 3"
    },
    {
      "path": "/api/cron/ops-meta-metrics",
      "schedule": "0 16 * * 3"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
