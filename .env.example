# BringhurstDO Ops phase 1/2 local configuration.
# Do not put live secrets, API tokens, PHI, raw logs, or clinical payloads here.

OPS_BASIC_AUTH_USERNAME=
OPS_BASIC_AUTH_PASSWORD_SHA256=
CRON_SECRET=

# Phase 8C scheduled LinkedIn autopublish. Requires database + LinkedIn + CRON_SECRET.
OPS_AUTOPUBLISH_ENABLED=false
OPS_AUTOPUBLISH_TIMEZONE=America/New_York

# Phase 5C durable persistence. Leave empty/local unless a Postgres database is
# explicitly approved and provisioned. DATABASE_URL must stay server-only.
OPS_STORAGE_MODE=local-browser
DATABASE_URL=

# Phase 6A AI draft improvement only. Server-only. Disabled by default.
OPS_AI_ENABLED=false
OPS_AI_PROVIDER=openai
# Optional override. Gemini default: gemini-3.5-flash. OpenAI default: gpt-4o-mini.
OPS_AI_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=
